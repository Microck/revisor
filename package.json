    "cmd",
    "internal",
    "scripts",
    "go.mod",
    "README.md",
    ".github/assets"
  ],
  "scripts": {
    "build": "go build -o bin/revisor-go ./cmd/revisor",
    "build:prebuilts": "node ./scripts/build-prebuilts.js",
    "test": "go test ./...",
    "postinstall": "node ./scripts/postinstall.js"
  },
  "optionalDependencies": {
    "@microck/revisor-darwin-arm64": "0.1.4",
    "@microck/revisor-darwin-x64": "0.1.4",
    "@microck/revisor-linux-arm64": "0.1.4",
    "@microck/revisor-linux-x64": "0.1.4",
    "@microck/revisor-win32-arm64": "0.1.4",
    "@microck/revisor-win32-x64": "0.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}

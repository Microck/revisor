{
  "name": "@microck/revisor",
  "version": "0.1.4",
  "description": "portable codex-powered github pr review, debugging, and issue-fixing cli.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Microck/revisor.git"
  },
  "homepage": "https://github.com/Microck/revisor#readme",
  "bugs": {
    "url": "https://github.com/Microck/revisor/issues"
  },
  "bin": {
    "revisor": "bin/revisor.js"
  },
  "files": [
